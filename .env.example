# ── KIS API Credentials ──────────────────────────────────────────────
# For demo mode (--demo), these placeholders are fine.
# For production, replace with your real KIS Developers credentials.
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_CANO=00000000
KIS_ACNT_PRDT_CD=01

# ── API Environment ──────────────────────────────────────────────────
# "virtual" for simulated trading (모의투자), "real" for production.
KIS_ENV=virtual

# ── Target Stocks ────────────────────────────────────────────────────
# Comma-separated list of 6-digit Korean stock codes.
TARGET_STOCKS=005930,000660

# ── WebSocket ────────────────────────────────────────────────────────
WS_RECONNECT_DELAY_SEC=3
WS_MAX_RECONNECTS=0
WS_HEARTBEAT_INTERVAL_SEC=30

# ── Data Pipeline ────────────────────────────────────────────────────
OHLCV_BAR_SECONDS=60
MAX_TICK_BUFFER=10000

# ── Feature Engineering ──────────────────────────────────────────────
VWAP_WINDOW=20
RSI_WINDOW=14
OI_WINDOW=10

# ── ML / Rules Engine ────────────────────────────────────────────────
PREDICTION_CONFIDENCE_THRESHOLD=0.6
MOCK_PREDICTIONS=true